# ---- Server ----
PORT=3000
NODE_ENV=production

# ---- Persistence on Vercel (blog posts, bookings, testimonials, payments, queue, stats) ----
# The read-only filesystem on Vercel means the app can't write JSON files to
# disk in production the way it does locally/on Termux. Connect a Vercel KV
# store (Storage tab in your Vercel project → Create Database → KV) and it
# will inject these two automatically; no code changes needed. Without them,
# the app still runs on Vercel but falls back to in-memory storage that
# resets on every cold start — fine for a demo, not for real data.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ---- Email delivery: Resend (recommended) ----
# Resend sends over HTTPS (port 443), unlike raw SMTP. This matters a lot on
# Termux/Android and mobile-carrier networks, which frequently block outbound
# SMTP ports 587/465 and cause "Greeting never received" errors — that's a
# blocked connection, not a bad password, and no SMTP retry fixes it.
# Get a free API key at https://resend.com (no card required for the free tier).
# If RESEND_API_KEY is set, it's tried first; SMTP below is the fallback.
RESEND_API_KEY=
RESEND_FROM="Boatek Labs <onboarding@resend.dev>"

# ---- Nodemailer (SMTP) — fallback if Resend isn't set or a send fails ----
# For Gmail: use an App Password, not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Where contact form submissions should be delivered
CONTACT_TO_EMAIL=boateklabs@gmail.com
CONTACT_FROM_NAME=Boatek Labs Portfolio

# Comma-separated list of allowed origins for CORS (leave blank to allow same-origin only)
ALLOWED_ORIGINS=

# ---- Admin dashboard (/admin.html) ----
# Protects /api/admin/* with HTTP Basic Auth. Leave blank to disable the
# dashboard entirely. Pick your own values — these are not real credentials.
ADMIN_USER=
ADMIN_PASS=

# ---- Telegram notifications (optional) ----
# Instant push notification for new inquiries/bookings/testimonials/payments,
# faster to notice on a phone than email. Create a bot via @BotFather, then
# message your bot once and fetch your chat ID from
# https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Paystack (optional, for the "Start with a deposit" button) ----
# Public key is used client-side (index.html), secret key verifies payments
# server-side. Get both from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
